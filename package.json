{
  "name": "orkas",
  "version": "2026.6.20",
  "private": true,
  "description": "Orkas desktop — Electron + Node one-piece app",
  "main": "bootstrap.cjs",
  "type": "commonjs",
  "packageManager": "npm@11.11.0",
  "imports": {
    "#core-agent": "./src/core-agent/src/index.ts"
  },
  "scripts": {
    "start": "node bin/ensure-runtime.cjs --root resources/runtime && node scripts/fetch-officecli.cjs && electron .",
    "stop": "pkill -9 -f \"$PWD/node_modules/electron/dist\" || true",
    "smoke": "tsx src/main/smoke.ts",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs run",
    "test:watch": "node scripts/run-tests.mjs",
    "runtime:ensure": "node bin/ensure-runtime.cjs --root resources/runtime",
    "officecli:fetch": "node scripts/fetch-officecli.cjs",
    "rebuild:sqlite:electron": "node scripts/swap-sqlite-abi.mjs electron",
    "rebuild:sqlite:node": "node scripts/swap-sqlite-abi.mjs node",
    "postinstall": "node scripts/swap-sqlite-abi.mjs electron && node scripts/fetch-embedding-model.mjs",
    "prepare": "node scripts/install-git-hooks.mjs",
    "prepack": "node bin/ensure-runtime.cjs --root resources/runtime && node scripts/fetch-officecli.cjs && node scripts/swap-sqlite-abi.mjs electron"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^25.6.0",
    "electron": "^41.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.10.0",
    "electron-log": "^5.4.3",
    "fastembed": "^2.1.0",
    "jimp": "^1.6.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.22.4",
    "zod": "^3.24.0"
  },
  "overrides": {
    "tar": "7.5.16"
  },
  "build": {
    "appId": "com.orkas.desktop",
    "productName": "Orkas",
    "protocols": [
      {
        "name": "Orkas",
        "schemes": [
          "orkas"
        ],
        "role": "Viewer"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "bootstrap.cjs",
      "bin/**/*",
      "src/main/**/*.{js,ts,mjs,md,json}",
      "src/renderer/**/*",
      "src/resources/icons/**/*",
      "tsconfig.json",
      "node_modules/tsx/**/*",
      "node_modules/get-tsconfig/**/*",
      "node_modules/resolve-pkg-maps/**/*",
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*",
      "src/core-agent/package.json",
      "src/core-agent/src/**/*.ts",
      "!**/*.{py,pyc}",
      "!**/__pycache__",
      "!**/.DS_Store",
      "!src/core-agent/test/**",
      "!src/main/features/*_dev.ts",
      "!src/main/ipc/dev_handlers.ts"
    ],
    "asar": true,
    "asarUnpack": [
      "bin/**/*",
      "node_modules/tsx/**/*",
      "node_modules/get-tsconfig/**/*",
      "node_modules/resolve-pkg-maps/**/*",
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/sqlite-vec*/**/*",
      "node_modules/fastembed/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/embedding-model",
        "to": "embedding-model",
        "filter": [
          "**/*",
          "!*.tar.gz"
        ]
      },
      {
        "from": "resources/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/officecli",
        "to": "officecli",
        "filter": [
          "**/*",
          "!*.part"
        ]
      },
      {
        "from": "resources/mac-locales",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "beforePack": "scripts/ensure-runtime-before-pack.cjs",
    "afterPack": "scripts/codesign-adhoc.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "product/signing/entitlements.mac.plist",
      "entitlementsInherit": "product/signing/entitlements.mac.inherit.plist",
      "notarize": false,
      "forceCodeSigning": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "src/resources/icons/icon.icns",
      "extendInfo": {}
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": "nsis",
      "icon": "src/resources/icons/icon.ico",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://ts.ssl.com"
      }
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "license": "MIT"
}
